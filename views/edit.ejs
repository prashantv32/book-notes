<%- include("partials/header.ejs") %>

<main>
    <div class="container">
        <div class="form-container">

            <h1>Edit book</h1>

            <form action="/edit/<%= book.id %>" method="POST">

                <div class="form-group">
                    <label>Title</label>
                    <input type="text" name="title" value="<%= book.title %>" required />
                </div>

                <div class="form-group">
                    <label>Author</label>
                    <input type="text" name="author" value="<%= book.author %>" required />
                </div>

                <div class="form-group">
                    <label>Rating (1–10)</label>
                    <input type="number" name="rating" min="1" max="10" value="<%= book.rating %>" required />
                </div>

                <div class="form-group">
                    <label>Date read</label>
                    <input type="date" name="date_read" value="<%= book.date_read ? book.date_read.toISOString().split('T')[0] : '' %>" />
                </div>

                <div class="form-group">
                    <label>Notes</label>
                    <textarea name="notes"><%= book.notes %></textarea>
                </div>

                <div class="form-group">
                    <label>isbn</label>
                    <input type="text" name="isbn" value="<%= book.isbn %>" />
                </div>

                <div style="display: flex; gap: 12px; align-items: center; margin-top: 2rem;">
                    <button type="submit" class="btn-primary">Save changes</button>
                    <a href="/" class="btn-edit">Back to home</a>
                </div>

            </form>

        </div>
    </div>
</main>

<%- include("partials/footer.ejs") %>