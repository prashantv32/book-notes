<%- include("partials/header.ejs") %>

<main>
    <div class="container">
        <div class="form-container">

            <h1>Add a book</h1>

            <form action="/add" method="POST">

                <div class="form-group">
                    <label>Title</label>
                    <input type="text" name="title" required />
                </div>

                <div class="form-group">
                    <label>Author</label>
                    <input type="text" name="author" required />
                </div>

                <div class="form-group">
                    <label>Rating (1–10)</label>
                    <input type="number" name="rating" min="1" max="10" required />
                </div>

                <div class="form-group">
                    <label>Date read</label>
                    <input type="date" name="date_read" />
                </div>

                <div class="form-group">
                    <label>Notes</label>
                    <textarea name="notes"></textarea>
                </div>

                <div class="form-group">
                    <label>isbn</label>
                    <input type="text" name="isbn" placeholder="e.g. 9780062315007" />
                    <small>find it on the back cover or search on <a href="https://openlibrary.org" target="_blank">openlibrary.org</a></small>
                </div>

                <div style="display: flex; gap: 12px; align-items: center; margin-top: 2rem;">
                    <button type="submit" class="btn-primary">Add book</button>
                    <a href="/" class="btn-edit">Back to home</a>
                </div>

            </form>

        </div>
    </div>
</main>

<%- include("partials/footer.ejs") %>